@foreach (var item in HeaderLinks)
{
    <NavLink class="header-link" href="@item.Href" Match="NavLinkMatch.All">
        <i class="bi @item.Icon" aria-hidden="true"></i>
        <span class="header-text">@item.Title</span>
    </NavLink>
}

@code {
    private List<INavMenuItem> HeaderLinks = new()
    {
        new NavMenuItem<Pages.Landing.Account>() { Title = "User Settings", Icon = "bi-person-circle" },
        new NavMenuItem<Pages.Admin.Settings>() { Title = "Application Settings", Icon = "bi-collection" },
        new NavMenuItem<Pages.Admin.Settings>() { Title = "Theme Settings", Uri = s => new () { Mode = DataLayer.Customization.ControlMode.List }, Icon = "bi-collection" },
        new NavMenuItem<Pages.Admin.Permissions>() { Title = "Permissions", Icon = "bi-activity" },
    };

}

