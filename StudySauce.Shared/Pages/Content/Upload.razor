@page "/upload"
@implements IDisposable
@using DataLayer.Utilities.Extensions
@using Microsoft.EntityFrameworkCore
@using StudySauce.Shared.Controls
@using StudySauce.Shared.Services
@using System.ComponentModel
@inject IFileManager File
@inject IMenuService MenuService
@inject IServiceProvider Services

<SyncedTitle Title="Import Packs"></SyncedTitle>

<div class="flash-card animate-in @(isDragOver ? "dropping" : "")"
     @ondragover:preventdefault="true"
     @ondragenter:preventdefault="true"
     @ondragover="HandleDragOver"
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop">
    <div class="drop-shader"><span class="bi bi-cloud-upload"></span><br /><span>Drop Anki Files</span></div>

    <h2>Upload Anki</h2>
    <heading class="flex-row">
        <label></label>
        <label>File Name</label>
        <label>Description</label>
        <label>Source</label>
        <label>Actions</label>
    </heading>
    <MetadataControl ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.File, object?>>(this, OnAnkiSelected))" TModel="DataLayer.Entities.File" Model="@FilesLayout" Data="@Uploads"></MetadataControl>


    Upload pack content from Anki or spreadsheet.<br />
    @if (!OperatingSystem.IsWindows())
    {
        <InputFile OnChange="HandleFileSelection" />
    }
    else
    {
        <button class="btn btn-primary" @onclick="() => File.OpenFileDialog()">
            <i class="bi bi-file-earmark-plus"></i> Open File
        </button>
    }

    <h2>Content Controls</h2>

    Import content into a group or release schedule.
    <h4>Anki Files</h4>
    <heading class="flex-row">
        <label></label>
        <label>File Name</label>
        <label>Description</label>
        <label>Source</label>
        <label>Actions</label>
    </heading>
    <MetadataControl TModel="DataLayer.Entities.File" Model="@FilesLayout" Data="@Inside"></MetadataControl>


    <h4>Converted Cards</h4>
    <heading class="flex-row">
        <label></label>
        <label>Prompt</label>
        <label>Response</label>
        <label>Type</label>
        <label>Answers</label>
        <label>Actions</label>
    </heading>
    <MetadataControl TModel="Controls.EditCardControl.EditControl" Model="@CardsLayout" Data="@CurrentCards"></MetadataControl>

    <h2>Content Sharing</h2>

    Notify users now or distribute to subscribers.

</div>


@code
{
    // TODO: decide when to synchronize the file storage with memory storage
    public static EntityMetadata Metadata => new EntityMetadata(typeof(Pages.Content.Upload));
    [Category("Display")]
    public IEnumerable<DataLayer.Entities.File>? Uploads { get; set; }
    public IEnumerable<DataLayer.Entities.File>? Inside { get; set; }
    [Category("Content")]
    public List<Controls.EditCardControl.EditControl>? CurrentCards { get; set; }
    public IEnumerable<PropertyMetadata>? FilesLayout { get; set; }
    public IEnumerable<PropertyMetadata>? CardsLayout { get; set; }

    bool isDragOver = false;

    void HandleDragOver() => File.SetDragging(true);
    void HandleDragLeave() => File.SetDragging(false);

    protected override void OnInitialized()
    {
        base.OnInitialized();
        MenuService?.SetMenu(@<StudySauce.Shared.Pages.Shared.Packs />);
        FilesLayout = Pages.Content.Upload.Metadata.Categories["Display"]?.ToList();
        CardsLayout = Pages.Content.Upload.Metadata.Categories["Content"]?.ToList();
        File.OnFileDragging += OnDragging;
    }

    protected void OnAnkiSelected(Tuple<PropertyMetadata, DataLayer.Entities.File, object?> callback)
    {
        var ankiResults = callback.Item3 as Tuple<IEnumerable<DataLayer.Entities.File>, IEnumerable<DataLayer.Entities.Card>>;
        if (ankiResults == null) return;

        Inside = ankiResults.Item1;
        CurrentCards = ankiResults.Item2.Select(c => new EditCardControl.EditControl() { Card = c }).ToList();
    }


    public IDbContextFactory<DataLayer.PersistentStorage>? PersistentFactory { get {
            try {
                return Services.GetService(typeof(IDbContextFactory<DataLayer.PersistentStorage>)) as IDbContextFactory<DataLayer.PersistentStorage>;
            } catch (Exception ex)
            {
                return null;
            }
        }
    }

    [Inject] 
    public IDbContextFactory<DataLayer.EphemeralStorage>? MemoryFactory { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _ = base.OnInitializedAsync();

        if(PersistentFactory == null || MemoryFactory == null)
        {
            await PopulateUploads();
            return;
        }
        using var fileContext = PersistentFactory.CreateDbContext();
        using var memoryContext = MemoryFactory.CreateDbContext();
        await fileContext.Sync(memoryContext, (DataLayer.Entities.File f) => f.Source == "Upload");
        await PopulateUploads(memoryContext);
    }

    protected async Task PopulateUploads(EphemeralStorage? memoryContext = null)
    {
        if (MemoryFactory == null)
        {
            return;
        }
        if (memoryContext == null)
        {
            memoryContext = MemoryFactory.CreateDbContext();
        }
        Uploads = await memoryContext.Files.Where(f => f.Source == "Upload").ToListAsync();
    }


    protected void OnDragging(bool dragging)
    {
        isDragOver = dragging;
        StateHasChanged();
    }

    protected async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        isDragOver = false;
        // Process the dropped files
        foreach (var file in e.GetMultipleFiles())
        {
            _ = File.UploadFile(file.OpenReadStream(), file.Name);
            // Access file properties like file.Name, file.Size, etc.
            // You can read the file stream here:
            // using var stream = file.OpenReadStream();
            // ... further processing ...
        }
        StateHasChanged();
    }



    protected async Task HandleDrop(DragEventArgs e)
    {
        _ = File.SetDragging(false);
        // In Blazor Hybrid, e.DataTransfer.Files is usually populated
        if (e.DataTransfer.Files != null)
        {
            foreach (var file in e.DataTransfer.Files)
            {
                _ = File.UploadFile(file);
            }
        }

        StateHasChanged();

    }



    public void Dispose()
    {
        File.OnFileDragging -= OnDragging;
    }
}
