@page "/packs"
@page "/packs/{Id:int}/add"
@using StudySauce.Shared.Controls
@using StudySauce.Shared.Services
@using System.ComponentModel
@inject IMenuService MenuService

<SyncedTitle Title="Study Packs"></SyncedTitle>

<div class="flash-card animate-in">

    @* do advertising for packs needing study *@
    <h2>Recent Packs</h2>
    <heading class="flex-row">
        <label></label>
        <label>Pack Name</label>
        <label>Category</label>
        <label>Card Count</label>
        <label>Last Studied</label>
        <label>Actions</label>
    </heading>
    <MetadataControl TModel="DataLayer.Entities.Pack" Model="@RecentLayout" Data="Recent"></MetadataControl>


    <h2>Packs Needing Study</h2>


    <h2>Packs You Might Like</h2>

</div>

@code {
    public static EntityMetadata Metadata => new EntityMetadata(typeof(Pages.Landing.Packs));

    [Category("Recent")]
    public List<DataLayer.Entities.Pack> Recent { get; set; } = new();
    public List<DataLayer.Entities.Pack> Study { get; set; } = new();
    public List<DataLayer.Entities.Pack> Store { get; set; } = new();

    public IEnumerable<PropertyMetadata>? RecentLayout { get; set; }
    [Parameter]
    public int? Id { get; set; } = null;
    public DataLayer.Customization.ControlMode? ControlMode { get; set; } = DataLayer.Customization.ControlMode.List;

    protected override void OnInitialized()
    {
        // Define the contextual menu for THIS page
        MenuService?.SetMenu(@<StudySauce.Shared.Pages.Shared.Packs />);
        RecentLayout = Pages.Landing.Packs.Metadata.Categories["Recent"]?.ToList();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        Recent.Clear();
        foreach (var course in (Type[])([typeof(Pages.Course.Course1), typeof(Pages.Course.Course2), typeof(Pages.Course.Course3)]))
        {
            var packs = GetCoursePack(course);
            Recent.AddRange(packs ?? []);
        }
        StateHasChanged();
    }

    protected static IEnumerable<DataLayer.Entities.Pack>? GetCoursePack(Type? lesson)
    {
        var generator = lesson?.GetMethod("Generate", System.Reflection.BindingFlags.Static | System.Reflection.BindingFlags.Public);
        IEnumerable<DataLayer.Entities.Pack>? packs = generator?.Invoke(null, []) as IEnumerable<DataLayer.Entities.Pack>;
        return packs;
    }

}