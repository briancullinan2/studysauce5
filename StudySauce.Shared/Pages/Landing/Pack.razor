@page "/shuffle"
@page "/pack/{Id:int}"
@page "/quiz/{Id:int}"
@page "/card/{Id:int}"
@page "/demo/{Id:int}"
@inject NavigationManager Nav
@inject ILoginService LoginService
@using StudySauce.Shared.Services
@using StudySauce.Shared.Controls
@using System.ComponentModel
@using System.Reflection
@using StudySauce.Shared.Utilities.Extensions
@using DataLayer.Customization
@using System.Text.Json.Serialization

@if (Mode == null)
{
    <NotFoundControl />
    return;
}

@for(var i = 0; i < CurrentQuiz?.Count(); i++)
{
    var card = CurrentQuiz?.ElementAt(i);

    <div class="flash-card @(GetDisplayClass(i * 2))">
        <MetadataControl ValueChanged="@(EventCallback.Factory.Create<Tuple<PropertyMetadata, DataLayer.Entities.Card, object?>>(this, OnQuizAnswered))" TModel="DataLayer.Entities.Card" Model="@CardLayout" Data="[card]"></MetadataControl>
    </div>

    <div class="flash-card @(GetDisplayClass(i * 2 + 1))">
        <MetadataControl TModel="Controls.ResultsCardControl.ResultCard" Model="@ResultLayout" Data="[new Controls.ResultsCardControl.ResultCard() { Card = card, Response = Responses.FirstOrDefault(r => r.Card == card) }]"></MetadataControl>
    </div>
}

@*TODO: show results screen if retention is already resolved*@

@* Progress Tracker *@
@if (TotalCards != null)
{
    <ul class="tab-tracker">
        @for (var i = Math.Max((int)QuizStep - 2, 0); i < Math.Min((int)TotalCards, (int)QuizStep + 3); i++)
        {
            <li class="@(i == QuizStep ? "text-amber-500 text-xl" : "text-slate-300")">
                &bullet;
                <span>@QuizStep</span>
            </li>
        }
    </ul>
    @*Add one for visual, CurrentIndex is zero based*@
    <div class="preview-count">@(QuizStep + 1) of @TotalCards</div>
}


@code {
    [Parameter] public int? Id { get; set; }
    [JsonPropertyName("quiz")]
    [Category("Display")]
    public IEnumerable<DataLayer.Entities.Card>? CurrentQuiz { get; set; }
    [JsonIgnore]
    [Category("Results")]
    public IEnumerable<Controls.ResultsCardControl.ResultCard>? Results { get; set; }

    // TODO:
