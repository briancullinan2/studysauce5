    public PackMode? Mode { get; set; }
    private List<DataLayer.Entities.Response> Responses = new();
    private IEnumerable<PropertyMetadata>? CardLayout;
    private IEnumerable<PropertyMetadata>? ResultLayout;
    public int? PreviousStep { get; set; }
    public int QuizStep { get; set; } = 0;
    public int? TotalCards { get => CurrentQuiz?.Count(); }


    public static EntityMetadata Metadata => new EntityMetadata(typeof(Pages.Landing.Pack));

    protected override void OnInitialized()
    {
        base.OnInitialized();
        CardLayout = Pages.Landing.Pack.Metadata.Categories["Display"]?.ToList();
        ResultLayout = Pages.Landing.Pack.Metadata.Categories["Results"]?.ToList();
    }

    protected string? GetDisplayClass(int? step)
    {
        if (QuizStep == step) return "animate-in";
        if (PreviousStep == step) return "animate-out";
        return "hidden";
    }


    protected override void OnParametersSet()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);

        var firstSegment = relativePath.Split('/')[0];

        Mode = firstSegment.TryParse<PackMode>();

        if (Mode == PackMode.Shuffle)
        {
            // TODO: if user hasn't logged in, shuffle 5 built in study sauce and then ask for sign up like demo sequence


            CurrentQuiz = LoginService.User?.UserPacks.SelectMany(up =>
            {
                var due = up.GetRetention().Where(r => r.Value.IsDue).Select(r => r.Key);
                return up.Pack?.Cards.Where(c => due.Contains(c.Id)) ?? [];
            }).Shuffle();
        }
        else if (Id != null)
        {
            /*if (Id < 0 && Id >= -3)
            {
                Type[] packs = [typeof(Pages.Course.Course1), typeof(Pages.Course.Course2), typeof(Pages.Course.Course3)];
                CurrentQuiz = GetCoursePack(packs.ElementAt(Math.Abs(Id ?? 0) - 1))?.FirstOrDefault()?.Cards;
            }*/
            // only show one id quiz
            var up = LoginService.User?.UserPacks.FirstOrDefault(up => up.Pack?.Id == Id);
            var due = up?.GetRetention().Where(r => r.Value.IsDue).Select(r => r.Key).ToList() ?? [];
            CurrentQuiz = up?.Pack?.Cards.Where(c => due.Contains(c.Id) == true) ?? [];
        }
    }

