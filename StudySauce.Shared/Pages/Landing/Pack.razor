    {
        var generator = lesson?.GetMethod("Generate", System.Reflection.BindingFlags.Static | System.Reflection.BindingFlags.Public);
        IEnumerable<DataLayer.Entities.Pack>? packs = generator?.Invoke(null, []) as IEnumerable<DataLayer.Entities.Pack>;
        return packs?.ToList();
    }
    */

    protected async Task OnQuizAnswered(Tuple<PropertyMetadata, DataLayer.Entities.Card, object?> valueChanged)
    {
        var answer = valueChanged.Item3 as DataLayer.Entities.Answer;
        if (answer == null)
        {
            return;
        }
        var response = new DataLayer.Entities.Response()
        {
            Answer = answer,
            Value = answer.Content ?? answer.Value ?? "",
            IsCorrect = answer.IsCorrect,
            Card = valueChanged.Item2
        };
        Responses.Add(response);
        QuizStep++;
        StateHasChanged();
    }

}