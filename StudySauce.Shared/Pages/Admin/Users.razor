@implements IDisposable
@page "/users"
@page "/users/add"
@page "/users/list"
@page "/users/{Id:int}"
@page "/users/{Id:int}/view"
@page "/users/{Id:int}/edit"
@using StudySauce.Shared.Controls
@using StudySauce.Shared.Services
@using System.ComponentModel
@inject IMenuService MenuService
@inject NavigationManager Nav

<SyncedTitle Title="User Management"></SyncedTitle>

<div class="flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.List)">
    <h2>Manage Users</h2>
    <MetadataControl TModel="DataLayer.Entities.User" Model="@UserLayout" Data="CurrentUsers"></MetadataControl>


    <h2>User Controls</h2>
    <a href="@(NavigationExtensions.GetUri<Pages.Admin.Users>(u => new () {ControlMode = DataLayer.Customization.ControlMode.Add}))"><i class="bi bi-person-plus" aria-hidden="true"></i> Add User</a>

    <h2>Recent Activity</h2>
</div>

<div class="flash-card @GetDisplayClass(DataLayer.Customization.ControlMode.Add)">
    <h2>New User</h2>

</div>



@code {
    public static EntityMetadata Metadata => new EntityMetadata(typeof(Pages.Admin.Users));

    [Category("Display")]
    public IEnumerable<DataLayer.Entities.User>? CurrentUsers { get; set; }
    public IEnumerable<PropertyMetadata>? UserLayout { get; set; }
    public IEnumerable<PropertyMetadata>? GeneralLayout { get; set; }
    public DataLayer.Customization.ControlMode? ControlMode { get; set; }
    public DataLayer.Customization.ControlMode? PreviousMode { get; set; }
    [Parameter] public int? Id { get; set; }

    protected string? GetDisplayClass(DataLayer.Customization.ControlMode mode)
    {
        if (ControlMode == mode) return "animate-in";
        if (PreviousMode == mode) return "animate-out";
        return "hidden";
    }

    protected override void OnInitialized()
    {
        // Define the contextual menu for THIS page
        MenuService?.SetMenu(@<StudySauce.Shared.Pages.Shared.Users />);
        UserLayout = Pages.Admin.Users.Metadata.Categories["Display"]?.ToList();
        GeneralLayout = DataLayer.EntityMetadata.User.Groups["General Info"]?.ToList();
        Nav.LocationChanged += OnLocationChanged;

    }

    protected void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        SetControlMode();
    }

    protected void SetControlMode()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);

        var segments = relativePath.Split('/');

        DataLayer.Customization.ControlMode? newStep = DataLayer.Customization.ControlMode.List;
        if(segments.Count() == 2 && Id != null)
        {
            newStep = DataLayer.Customization.ControlMode.View;
        }
        else if (segments.Count() >= 2)
        {
            newStep = segments.Last().TryParse<DataLayer.Customization.ControlMode>() ?? DataLayer.Customization.ControlMode.List;
        }
        if (newStep != ControlMode)
        {
            PreviousMode = ControlMode;
            ControlMode = newStep;
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        CurrentUsers = DataLayer.Generators.Users.Generate();
        SetControlMode();
        StateHasChanged();
    }

    
    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}